---
const services = [
  { name: 'Arreglos Locativos', image: '/arreglos-locativos.jpg', color: '#1A9305', orientation: 'right' },
  { name: 'Plomería', image: '/plomeria.jpg', color: '#EE6910', orientation: 'left' },
  { name: 'Eléctricos', image: '/electricos.jpg', color: '#1A9305', orientation: 'right' },
];
---

<div style="background-color: #ed792b;" class="py-8 px-4 mb-10">
  <div class="max-w-5xl mx-auto">
    <h2
      id="remodeling-section"
      class="font-semibold text-xl text-white mb-6 text-center lg:text-2xl"
    >
      Nuestros servicios
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      {
        services.map((service) => (
          <article class="w-full">
            <div class="relative" style="max-width: 600px;">
              <img
                class="w-full h-[150px] md:h-[220px] lg:h-[230px] object-cover object-center rounded-lg shadow-lg"
                src={service.image}
                alt={service.name}
                loading="lazy"
              />
              <!-- Full image color overlay -->
              <div
                class="absolute w-full h-full top-0 left-0 rounded-lg"
                style={`background-color: ${service.color}; opacity: 0.25;`}
              />
              <!-- Bottom thumbnail overlay -->
              <div
                class="absolute w-full bottom-0 right-0 flex rounded-b-lg"
                style={`background-color: ${service.color}; opacity: 0.35;`}
              >
                <h3 class="font-bold text-xl text-transparent m-2">.</h3>
              </div>
              <!-- Name label -->
              <h3
                class={`font-bold text-xl text-white m-2 absolute bottom-0 ${service.orientation === 'right' ? 'right-0' : 'left-0'}`}
              >
                {service.name.toUpperCase()}
              </h3>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</div>
