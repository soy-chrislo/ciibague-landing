---
const NAV_LINKS = [
  { href: '/mapa/sale', label: 'Ventas' },
  { href: '/mapa/rent', label: 'Arriendos' },
  { href: '/remodelaciones', label: 'Remodelaciones' },
];
---

<div class="w-full relative">
  <section class="flex justify-between items-center w-full lg:bg-black lg:bg-opacity-50 px-5 py-4">
    <a href="/" class="flex items-center space-x-3 relative">
      <img src="/ci-logo-blanco.png" alt="Contacto Inmobiliario" class="w-[528px] lg:w-[480px]" />
    </a>
    <nav class="hidden lg:flex items-center gap-10">
      {
        NAV_LINKS.map((link) => (
          <a
            href={link.href}
            class="text-white font-semibold text-sm tracking-wide hover:text-orange-400 transition-colors duration-200"
          >
            {link.label.toUpperCase()}
          </a>
        ))
      }
    </nav>
    <button
      type="button"
      id="mobile-menu-btn"
      class="lg:hidden flex flex-col justify-center items-center gap-1.5 p-2 rounded-md text-white hover:bg-white/10 transition-colors"
      aria-label="Abrir menú"
    >
      <span class="block w-6 h-0.5 bg-white transition-all duration-300" id="bar1"></span>
      <span class="block w-6 h-0.5 bg-white transition-all duration-300" id="bar2"></span>
      <span class="block w-6 h-0.5 bg-white transition-all duration-300" id="bar3"></span>
    </button>
  </section>
  <nav
    id="mobile-menu"
    class="lg:hidden hidden absolute top-full left-0 right-0 z-50 bg-black/90 backdrop-blur-sm"
  >
    <ul class="flex flex-col">
      {
        NAV_LINKS.map((link) => (
          <li class="border-b border-white/10">
            <a
              href={link.href}
              class="block px-6 py-4 text-white font-semibold text-base hover:bg-white/10 hover:text-orange-400 transition-colors"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const bar1 = document.getElementById('bar1');
  const bar2 = document.getElementById('bar2');
  const bar3 = document.getElementById('bar3');
  let isOpen = false;

  btn?.addEventListener('click', () => {
    isOpen = !isOpen;
    menu?.classList.toggle('hidden', !isOpen);
    bar1?.classList.toggle('rotate-45', isOpen);
    bar1?.classList.toggle('translate-y-2', isOpen);
    bar2?.classList.toggle('opacity-0', isOpen);
    bar3?.classList.toggle('-rotate-45', isOpen);
    bar3?.classList.toggle('-translate-y-2', isOpen);
  });
</script>
