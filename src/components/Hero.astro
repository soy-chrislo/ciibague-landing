---
import { fetchApi } from '../lib/api';
import Navbar from './Navbar.astro';

// Fetch Ibagué neighborhoods for search dropdown (SSR, cached per request)
let neighborhoods: Array<{ id: string; name: string; communeName?: string }> = [];
try {
  const cities = await fetchApi<Array<{ id: string; code: string; name: string }>>('/geo/cities');
  const ibague = cities.find((c) => c.code === '73001');
  if (ibague) {
    const rawNbh = await fetchApi<Array<{ id: string; name: string; communeId?: string }>>(
      `/geo/neighborhoods?cityId=${ibague.id}`
    );
    const communes = await fetchApi<Array<{ id: string; number: number; name: string }>>(
      `/geo/communes?cityId=${ibague.id}`
    );
    const communeMap = new Map(communes.map((c) => [c.id, c.name] as const));
    neighborhoods = rawNbh.map((n) => ({
      id: n.id,
      name: n.name,
      communeName: n.communeId ? communeMap.get(n.communeId) : undefined,
    }));
    neighborhoods.sort((a, b) => a.name.localeCompare(b.name));
  }
} catch (e) {
  console.error('Hero: could not load neighborhoods', e);
}
