<script is:inline>
  // Toggle form action based on radio choice (minimal inline JS, no island)
  const form = document.getElementById('hero-search');
  if (form) {
    form.addEventListener('change', (e) => {
      const target = e.target;
      if (target instanceof HTMLInputElement && target.classList.contains('hero-action-radio')) {
        form.setAttribute('action', target.value);
      }
    });
    // Clean: remove _action name from radios before submission so it doesn't pollute query params
    form.addEventListener('submit', () => {
      const radios = form.querySelectorAll('.hero-action-radio');
      radios.forEach((r) => r.removeAttribute('name'));
    });
  }
</script>
