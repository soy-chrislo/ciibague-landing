 3.68637C3.72621 3.16448 4.07026 2.7366 4.49137 2.42974L4.38988 2.17602C4.21399 1.73629 3.78809 1.44794 3.31449 1.44794ZM2.39189 8.53127C2.36351 8.53127 2.34662 8.53127 2.33386 8.53141C2.32458 8.53155 2.32127 8.5317 2.32115 8.5317C2.32068 8.5317 2.32111 8.5317 2.32115 8.5317C2.23256 8.53743 2.16264 8.60784 2.15664 8.69638C2.15661 8.69723 2.15649 8.70078 2.1564 8.70892C2.15625 8.72167 2.15624 8.73853 2.15624 8.76693C2.15624 9.05211 2.15646 9.17394 2.16513 9.31051C2.29648 11.38 4.07414 13.2258 6.13724 13.4347C6.27534 13.4487 6.35178 13.4516 6.53373 13.4585C7.04941 13.4778 7.54871 13.4896 7.99999 13.4896C8.45127 13.4896 8.95057 13.4778 9.46624 13.4585C9.64821 13.4516 9.72464 13.4487 9.86277 13.4347C11.9259 13.2258 13.7035 11.38 13.8349 9.31051C13.8435 9.17394 13.8437 9.05211 13.8437 8.76693C13.8437 8.73853 13.8437 8.72167 13.8436 8.70892C13.8435 8.7017 13.8434 8.69808 13.8434 8.69681C13.8433 8.69589 13.8433 8.69596 13.8434 8.69681C13.8376 8.60805 13.7669 8.53743 13.6781 8.53162C13.679 8.5317 13.6792 8.5317 13.6781 8.53162C13.6767 8.53162 13.673 8.53148 13.6661 8.53141C13.6533 8.53127 13.6365 8.53127 13.6081 8.53127H2.39189ZM6.78336 3.08952C6.31774 2.89061 5.81444 2.91829 5.38421 3.12773C5.00251 3.31355 4.67874 3.64278 4.49871 4.08613C4.38288 4.37134 4.341 4.66842 4.36375 4.95474L7.46704 3.61877C7.29038 3.39117 7.05883 3.20722 6.78336 3.08952Z"
            fill="black"
          />
        </svg>
        {bathrooms}
      </p>
      <!-- Car/parking icon -->
      <p class="flex justify-center items-baseline">
        <svg class="mr-2" width="16" height="14" viewBox="0 0 16 14" fill="none" xmlns="http://www.w3.org/2000/svg">
          <title>Car Icon</title>
          <path
            d="M0.5 3.57141L2.76822 5.51558C2.91798 5.64398 3.10676 5.71427 3.30171 5.71427H12.6982C12.8932 5.71427 13.082 5.64398 13.2317 5.51558L15.5 3.57141M3.41667 8.71427H3.425M12.5833 8.71427H12.5917M4.80054 0.571411H11.1995C11.7976 0.571411 12.3498 0.901043 12.6465 1.43517L15.0608 5.78087C15.3486 6.29892 15.5 6.88521 15.5 7.48195V12.5714C15.5 13.0448 15.1269 13.4286 14.6667 13.4286H13.8333C13.3731 13.4286 13 13.0448 13 12.5714V11.7143H3V12.5714C3 13.0448 2.6269 13.4286 2.16667 13.4286H1.33333C0.8731 13.4286 0.5 13.0448 0.5 12.5714V7.48195C0.5 6.88521 0.651383 6.29892 0.939192 5.78087L3.35347 1.43517C3.6502 0.901043 4.20244 0.571411 4.80054 0.571411ZM3.83333 8.71427C3.83333 8.95092 3.64678 9.14284 3.41667 9.14284C3.18655 9.14284 3 8.95092 3 8.71427C3 8.47761 3.18655 8.2857 3.41667 8.2857C3.64678 8.2857 3.83333 8.47761 3.83333 8.71427ZM13 8.71427C13 8.95092 12.8134 9.14284 12.5833 9.14284C12.3532 9.14284 12.1667 8.95092 12.1667 8.71427C12.1667 8.47761 12.3532 8.2857 12.5833 8.2857C12.8134 8.2857 13 8.47761 13 8.71427Z"
            stroke="black"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
        {parkingLots}
      </p>
    </div>

    <!-- Property Status badge matching legacy -->
    <div
      class="inline-flex items-center justify-center rounded-md p-2 mb-1"
      style="background-color: #F1F1F4;"
    >
      <div
        class="w-3 h-3 rounded-full mr-3"
        style={`background-color: ${availability ? '#1A9305' : '#D45500'};`}
      ></div>
      <p class="text-xs font-semibold">{availability ? 'Disponible' : 'No disponible'}</p>
    </div>

    <p class="text-sm text-gray-500 mt-1.5 truncate">{address}</p>
  </div>
</a>
