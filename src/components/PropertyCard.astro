---
interface Props {
  propertyId: string;
  imageSrc?: string | null;
  price: string;
  address: string;
  rooms: number;
  bathrooms: number;
  parkingLots: number;
  availability: boolean;
  propertyType?: string;
}

const PROPERTY_TYPE_LABELS: Record<string, string> = {
  apartamento: 'Apartamento',
  casa: 'Casa',
  lote: 'Lote',
  oficina: 'Oficina',
  local: 'Local',
  bodega: 'Bodega',
  finca: 'Finca',
  negocio: 'Negocio',
  habitacion: 'Habitación',
  edificio: 'Edificio',
};

const {
  propertyId,
  imageSrc,
  price,
  address,
  rooms,
  bathrooms,
  parkingLots,
  availability,
  propertyType,
} = Astro.props;
const typeLabel = propertyType ? (PROPERTY_TYPE_LABELS[propertyType] ?? propertyType) : null;
const formattedPrice = Number(price).toLocaleString('es-CO');
---

<a
  href={`/property/${propertyId}`}
  class="block shrink-0 w-full sm:w-[320px] rounded-lg shadow-lg mb-5 bg-white hover:shadow-xl transition-shadow duration-200 no-underline text-inherit"
>
  <div class="relative w-full h-[200px] bg-gray-100 rounded-t-lg overflow-hidden">
    {
      imageSrc ? (
        <img
          class="w-full h-full object-cover"
          src={imageSrc}
          alt={`Inmueble en ${address}`}
          loading="lazy"
        />
      ) : (
        <div class="w-full h-full flex items-center justify-center bg-gray-100">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#d1d5db" stroke-width="1.5">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
            <polyline points="9 22 9 12 15 12 15 22" />
          </svg>
        </div>
      )
    }
    {
      typeLabel && (
        <span class="absolute top-2 left-2 bg-black/60 text-white text-xs font-semibold px-2 py-0.5 rounded">
          {typeLabel}
        </span>
      )
    }
  </div>
  <div class="p-3">
    <div class="flex justify-between items-start mb-2">
      <h3 class="font-semibold text-lg leading-tight">${formattedPrice}</h3>
      <div class="flex items-center gap-2 text-xs text-gray-500">
        <span>{rooms} hab</span>
        <span>{bathrooms} baños</span>
        <span>{parkingLots} parq</span>
      </div>
    </div>
    <span
      class={`inline-block px-2 py-0.5 rounded text-xs font-medium ${availability ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'}`}
    >
      {availability ? 'Disponible' : 'No disponible'}
    </span>
    <p class="text-sm text-gray-500 mt-1.5 truncate">{address}</p>
  </div>
</a>
