---
interface Props {
  propertyId: string;
  slug: string;
  imageSrc?: string | null;
  price: string;
  address: string;
  rooms: number;
  bathrooms: number;
  parkingLots: number;
  availability: boolean;
  propertyType?: string;
}

const PROPERTY_TYPE_LABELS: Record<string, string> = {
  apartamento: 'Apartamento',
  casa: 'Casa',
  lote: 'Lote',
  oficina: 'Oficina',
  local: 'Local',
  bodega: 'Bodega',
  finca: 'Finca',
  negocio: 'Negocio',
  habitacion: 'Habitación',
  edificio: 'Edificio',
};

const {
  slug,
  imageSrc,
  price,
  address,
  rooms,
  bathrooms,
  parkingLots,
  availability,
  propertyType,
} = Astro.props;
const typeLabel = propertyType ? (PROPERTY_TYPE_LABELS[propertyType] ?? propertyType) : null;
const formattedPrice = Number(price).toLocaleString('es-CO');
---

<a
  href={`/property/${slug}`}
  class="block shrink-0 w-full rounded-lg shadow-lg mb-5 bg-white hover:shadow-xl transition-shadow duration-200 no-underline text-inherit"
>
  <div class="relative w-full h-[200px] bg-gray-100 rounded-t-lg overflow-hidden">
    {
      imageSrc ? (
        <img
          class="w-full h-full object-cover"
          src={imageSrc}
          alt={`Inmueble en ${address}`}
          loading="lazy"
        />
      ) : (
        <div class="w-full h-full flex items-center justify-center bg-gray-100">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#d1d5db" stroke-width="1.5">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
            <polyline points="9 22 9 12 15 12 15 22" />
          </svg>
        </div>
      )
    }
    {
      typeLabel && (
        <span class="absolute top-2 left-2 bg-black/60 text-white text-xs font-semibold px-2 py-0.5 rounded">
          {typeLabel}
        </span>
      )
    }
  </div>
  <div class="p-3">
    <div class="flex justify-between items-start mb-2">
      <h3 class="font-semibold text-lg leading-tight">${formattedPrice}</h3>
    </div>

    <!-- Stats with icons -->
    <div class="flex items-center mb-2">
      <!-- House/rooms icon -->
      <p class="flex justify-center items-baseline mr-5">
        <svg class="mr-2" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <title>House Icon</title>
          <path
            d="M0.5 7.67892V12.237C0.5 13.1917 0.5 13.6693 0.704366 14.034C0.884122 14.3547 1.17075 14.6153 1.52356 14.7786C1.92425 14.9643 2.44905 14.9643 3.4971 14.9643H12.5029C13.5509 14.9643 14.075 14.9643 14.4757 14.7786C14.8285 14.6153 15.1161 14.3547 15.2958 14.034C15.5 13.6696 15.5 13.1928 15.5 12.24V7.67892C15.5 7.22354 15.4995 6.99572 15.4387 6.78376C15.3847 6.59599 15.2961 6.41826 15.1762 6.25767C15.0408 6.07644 14.8528 5.92616 14.4757 5.62628L9.97569 2.04663C9.27575 1.48983 8.92578 1.21157 8.53194 1.10568C8.18487 1.01238 7.81494 1.01238 7.46787 1.10568C7.07431 1.21149 6.72481 1.48949 6.02596 2.04544L1.52447 5.62628C1.14748 5.92616 0.959412 6.07644 0.824094 6.25767C0.704178 6.41826 0.614891 6.59599 0.560909 6.78376C0.5 6.99572 0.5 7.22354 0.5 7.67892Z"
            stroke="black"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
        {rooms}
      </p>
      <!-- Bathroom icon -->
      <p class="flex justify-center items-baseline mr-5">
        <svg class="mr-2" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <title>Bathroom Icon</title>
          <path
            fill-rule="evenodd"
            clip-rule="evenodd"
