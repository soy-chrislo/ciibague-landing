---
import { env } from '../config/env';

const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-900 text-gray-300 mt-10">
  <div class="max-w-6xl mx-auto px-6 py-10">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <p class="text-white font-bold text-xl mb-3">Contacto Inmobiliario</p>
        <p class="text-sm leading-relaxed text-gray-400">
          Tu agencia inmobiliaria de confianza en Ibagué. Ventas, arriendos y remodelaciones.
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wide mb-4">Navegación</h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a href="/mapa/sale" class="hover:text-orange-400 transition-colors">
              Inmuebles en Venta
            </a>
          </li>
          <li>
            <a href="/mapa/rent" class="hover:text-orange-400 transition-colors">
              Inmuebles en Arriendo
            </a>
          </li>
          <li>
            <a href="/remodelaciones" class="hover:text-orange-400 transition-colors">
              Remodelaciones
            </a>
          </li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wide mb-4">Contacto</h3>
        <ul class="space-y-2 text-sm">
          <li class="flex items-center gap-2">
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            <span>Calle 17 # 6-46 Interlaken, Ibagué</span>
          </li>
          <li>
            <a
              href={`tel:+${env.whatsappNumber}`}
              class="flex items-center gap-2 hover:text-orange-400 transition-colors"
            >
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path
                  d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"
                ></path>
              </svg>
              300 840 9769
            </a>
          </li>
          <li>
            <a
              href="mailto:contactoinmobiliarioibague@gmail.com"
              class="flex items-center gap-2 hover:text-orange-400 transition-colors break-all"
            >
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <rect width="20" height="16" x="2" y="4" rx="2"></rect>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
              </svg>
              contactoinmobiliarioibague@gmail.com
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div
      class="border-t border-gray-700 mt-8 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-gray-500"
    >
      <p>© {currentYear} Contacto Inmobiliario Ibagué. Todos los derechos reservados.</p>
      <a
        href={`https://wa.me/${env.whatsappNumber}`}
        target="_blank"
        rel="noreferrer"
        class="flex items-center gap-1.5 hover:text-orange-400 transition-colors"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"
          ></path>
          <path
            d="M12 0C5.373 0 0 5.373 0 12c0 2.146.564 4.158 1.549 5.9L0 24l6.304-1.654A11.95 11.95 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.75c-1.97 0-3.839-.533-5.454-1.463l-.39-.232-3.744.982.999-3.648-.254-.404A9.71 9.71 0 0 1 2.25 12c0-5.385 4.365-9.75 9.75-9.75S21.75 6.615 21.75 12s-4.365 9.75-9.75 9.75z"
          ></path>
        </svg>
        WhatsApp
      </a>
    </div>
  </div>
</footer>
