---
---

<div class="bg-white rounded-xl shadow-md p-6 max-w-sm w-full">
  <h3 class="text-xl font-bold text-gray-800 mb-1">Encuéntranos en Ibagué</h3>
  <div class="h-1 w-12 rounded mb-5" style="background-color: #EE6910;"></div>

  <div class="space-y-4">
    <!-- Address -->
    <a
      href="https://maps.google.com/?q=Calle+17+%23+6-46+Interlaken+Ibagué"
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-start gap-3 group"
    >
      <div class="mt-0.5 p-2 bg-orange-50 rounded-lg group-hover:bg-orange-100 transition-colors" style="color: #EE6910;">
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <title>Dirección</title>
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
          <circle cx="12" cy="10" r="3" />
        </svg>
      </div>
      <div>
        <p class="text-sm font-medium text-gray-500">Dirección</p>
        <p class="text-sm text-gray-800 group-hover:text-orange-500 transition-colors">
          Calle 17 # 6 - 46 Interlaken
        </p>
      </div>
    </a>

    <!-- Phone -->
    <a href="tel:+573008409769" class="flex items-start gap-3 group">
      <div class="mt-0.5 p-2 bg-orange-50 rounded-lg group-hover:bg-orange-100 transition-colors" style="color: #EE6910;">
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <title>Teléfono</title>
          <path
            d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"
          />
        </svg>
      </div>
      <div>
        <p class="text-sm font-medium text-gray-500">Teléfono</p>
        <p class="text-sm text-gray-800 group-hover:text-orange-500 transition-colors">
          300 840 9769
        </p>
      </div>
    </a>

    <!-- Email -->
    <a href="mailto:contactoinmobiliarioibague@gmail.com" class="flex items-start gap-3 group">
      <div class="mt-0.5 p-2 bg-orange-50 rounded-lg group-hover:bg-orange-100 transition-colors" style="color: #EE6910;">
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <title>Correo electrónico</title>
          <rect width="20" height="16" x="2" y="4" rx="2" />
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
        </svg>
      </div>
      <div>
        <p class="text-sm font-medium text-gray-500">Correo</p>
        <p class="text-sm text-gray-800 group-hover:text-orange-500 transition-colors break-all">
          contactoinmobiliarioibague@gmail.com
        </p>
      </div>
    </a>

    <!-- WhatsApp -->
    <a
      href="https://wa.me/573008409769"
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-start gap-3 group"
    >
      <div class="mt-0.5 p-2 bg-orange-50 rounded-lg group-hover:bg-orange-100 transition-colors" style="color: #EE6910;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <title>WhatsApp</title>
          <path
            d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"
          />
          <path
            d="M12 0C5.373 0 0 5.373 0 12c0 2.146.564 4.158 1.549 5.9L0 24l6.304-1.654A11.95 11.95 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.75c-1.97 0-3.839-.533-5.454-1.463l-.39-.232-3.744.982.999-3.648-.254-.404A9.71 9.71 0 0 1 2.25 12c0-5.385 4.365-9.75 9.75-9.75S21.75 6.615 21.75 12s-4.365 9.75-9.75 9.75z"
          />
        </svg>
      </div>
      <div>
        <p class="text-sm font-medium text-gray-500">WhatsApp</p>
        <p class="text-sm text-gray-800 group-hover:text-orange-500 transition-colors">
          300 840 9769
        </p>
      </div>
    </a>
  </div>
</div>
