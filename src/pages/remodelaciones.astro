---
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import { env } from '../config/env';
import RemodelacionesView from '../islands/RemodelacionesView';
import BaseLayout from '../layouts/BaseLayout.astro';
import { fetchApi } from '../lib/api';
import type { Remodeling } from '../types';

let initialItems: Remodeling[] = [];

try {
  const data = await fetchApi<{ items?: Remodeling[] } | Remodeling[]>('/remodelings?limit=10');
  initialItems = Array.isArray(data) ? data : (data.items ?? []);
} catch (e) {
  console.error('Error:', e);
}
---

<BaseLayout
  title="Remodelaciones"
  description="Explora increíbles transformaciones de antes y después."
>
  <!-- Hero with navbar -->
  <Hero slot="navbar" />

  <main class="min-h-screen bg-gradient-to-b from-white to-gray-50 py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold tracking-tight sm:text-5xl md:text-6xl">
          Galería de Transformaciones
        </h1>
        <p class="mt-3 text-xl text-gray-500">
          Explora increíbles transformaciones de antes y después
        </p>
      </div>

      <RemodelacionesView
        client:only="react"
        initialItems={initialItems}
        apiUrl={env.backendUrl}
      />
    </div>
  </main>

  <Footer slot="footer" />
</BaseLayout>
