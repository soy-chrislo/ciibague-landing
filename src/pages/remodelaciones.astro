---
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { fetchApi } from '../lib/api';
import type { Remodeling } from '../types';

let items: Remodeling[] = [];

try {
  const data = await fetchApi<{ items?: Remodeling[] } | Remodeling[]>('/remodelings?limit=50');
  items = Array.isArray(data) ? data : (data.items ?? []);
} catch (e) {
  console.error('Error:', e);
}
---

<BaseLayout
  title="Remodelaciones"
  description="Explora increíbles transformaciones de antes y después."
>
  <Navbar slot="navbar" />

  <div class="min-h-screen bg-gradient-to-b from-white to-gray-50 py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold tracking-tight sm:text-5xl md:text-6xl">
          Galería de Transformaciones
        </h1>
        <p class="mt-3 text-xl text-gray-500">
          Explora increíbles transformaciones de antes y después
        </p>
      </div>

      {
        items.length === 0 ? (
          <div class="text-center py-20">
            <h3 class="text-2xl font-semibold text-gray-400 mb-2">
              No hay remodelaciones disponibles
            </h3>
          </div>
        ) : (
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {items.map((item) => (
              <div class="overflow-hidden rounded-lg border shadow hover:shadow-lg transition-shadow duration-300">
                <div class="relative aspect-[4/3]">
                  <img
                    src={item.beforeImage}
                    alt={`Antes - ${item.title}`}
                    class="object-cover w-full h-full"
                    loading="lazy"
                  />
                  <div class="absolute top-2 left-2 bg-black/70 text-white px-2 py-1 rounded text-xs">
                    Antes
                  </div>
                </div>
                <div class="relative aspect-[4/3]">
                  <img
                    src={item.afterImage}
                    alt={`Después - ${item.title}`}
                    class="object-cover w-full h-full"
                    loading="lazy"
                  />
                  <div class="absolute top-2 left-2 bg-black/70 text-white px-2 py-1 rounded text-xs">
                    Después
                  </div>
                </div>
                <div class="p-4">
                  <h3 class="font-semibold text-lg mb-2">{item.title}</h3>
                  <p class="text-sm text-gray-500 line-clamp-2">{item.description}</p>
                </div>
              </div>
            ))}
          </div>
        )
      }
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>
