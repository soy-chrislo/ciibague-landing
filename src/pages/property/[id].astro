---
export const prerender = false;

import Footer from '../../components/Footer.astro';
import PropertyCard from '../../components/PropertyCard.astro';
import PropertyJsonLd from '../../components/seo/PropertyJsonLd.astro';
import PropertyView from '../../islands/PropertyView';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { fetchApi } from '../../lib/api';
import type { PaginatedPropertiesResponse, Property } from '../../types';

const { id } = Astro.params;

let property: Property | null = null;
let rentProperties: Property[] = [];
let saleProperties: Property[] = [];

try {
  const [propData, rentData, saleData] = await Promise.all([
    fetchApi<Property>(`/properties/${id}`),
    fetchApi<PaginatedPropertiesResponse>('/properties?type=rent&limit=10'),
    fetchApi<PaginatedPropertiesResponse>('/properties?type=sale&limit=10'),
  ]);
  property = propData;
  rentProperties = rentData.items || [];
  saleProperties = saleData.items || [];
} catch (e) {
  console.error('Error:', e);
  return Astro.redirect('/404');
}

if (!property) return Astro.redirect('/404');

const typeLabel = property.propertyType
  ? property.propertyType.charAt(0).toUpperCase() + property.propertyType.slice(1)
  : 'Inmueble';
const description = property.description || `${typeLabel} en ${property.address}, Ibagué`;
---

<BaseLayout title={property.address} description={description} ogImage={property.photos?.[0]}>
  <PropertyJsonLd property={property} slot="head" />

  <header
    class="flex items-center justify-between px-4 py-3 border-b border-gray-200 bg-white"
    slot="navbar"
  >
    <a
      href="/"
      class="inline-flex items-center gap-1 text-sm font-medium text-gray-500 hover:text-orange-500 transition-colors"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m15 18-6-6 6-6"/>
      </svg>
      Inicio
    </a>
    <a href="/">
      <img src="/ci-logo-normal.png" alt="Contacto Inmobiliario" class="h-10 object-contain" />
    </a>
    <span class="w-[80px]"></span>
  </header>

  <PropertyView client:only="react" property={property} />

  {
    rentProperties.filter((p) => p.id !== id).length > 0 && (
      <section class="max-w-full mx-4 sm:mx-6 lg:mx-8 my-5">
        <div class="flex justify-between items-center mb-4">
          <h2 class="font-semibold text-lg lg:text-2xl">Inmuebles en Arriendo</h2>
          <a href="/mapa/rent">
            <button type="button" class="text-white px-4 py-1.5 rounded text-sm font-medium transition-colors" style="background-color: #EE6910;">Ver mapa</button>
          </a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4" id="rent-grid">
          {rentProperties.filter((p) => p.id !== id).map((p) => (
            <div class="property-item-rent hidden">
              <PropertyCard propertyId={p.id} imageSrc={p.photos?.[0]} price={String(p.price)} address={p.address} rooms={p.bedrooms} bathrooms={p.bathrooms} parkingLots={p.parkingSpots} availability={p.available} propertyType={p.propertyType} />
            </div>
          ))}
        </div>
        <div class="flex justify-center mt-4" id="rent-load-more-container">
          <button type="button" id="rent-load-more" class="text-white px-6 py-2 rounded-lg font-semibold text-sm transition-all hover:opacity-90" style="background-color: #EE6910;">Cargar más</button>
        </div>
      </section>
    )
  }

  {
    saleProperties.filter((p) => p.id !== id).length > 0 && (
      <section class="max-w-full mx-4 sm:mx-6 lg:mx-8 my-5">
        <div class="flex justify-between items-center mb-4">
          <h2 class="font-semibold text-lg lg:text-2xl">Inmuebles en Venta</h2>
          <a href="/mapa/sale">
            <button type="button" class="text-white px-4 py-1.5 rounded text-sm font-medium transition-colors" style="background-color: #EE6910;">Ver mapa</button>
          </a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4" id="sale-grid">
          {saleProperties.filter((p) => p.id !== id).map((p) => (
            <div class="property-item-sale hidden">
              <PropertyCard propertyId={p.id} imageSrc={p.photos?.[0]} price={String(p.price)} address={p.address} rooms={p.bedrooms} bathrooms={p.bathrooms} parkingLots={p.parkingSpots} availability={p.available} propertyType={p.propertyType} />
            </div>
          ))}
        </div>
        <div class="flex justify-center mt-4" id="sale-load-more-container">
          <button type="button" id="sale-load-more" class="text-white px-6 py-2 rounded-lg font-semibold text-sm transition-all hover:opacity-90" style="background-color: #EE6910;">Cargar más</button>
        </div>
      </section>
    )
  }

  <script>
    function setupLoadMore(itemClass: string, btnId: string, containerId: string, pageSize = 10) {
      const items = document.querySelectorAll(`.${itemClass}`);
      const btn = document.getElementById(btnId);
      const container = document.getElementById(containerId);
      if (!items.length || !btn || !container) return;

      let visible = 0;
      function showNext() {
        const end = Math.min(visible + pageSize, items.length);
        for (let i = visible; i < end; i++) {
          items[i].classList.remove('hidden');
        }
        visible = end;
        if (visible >= items.length && container) container.style.display = 'none';
      }
      showNext();
      btn.addEventListener('click', showNext);
    }

    setupLoadMore('property-item-rent', 'rent-load-more', 'rent-load-more-container');
    setupLoadMore('property-item-sale', 'sale-load-more', 'sale-load-more-container');
  </script>

  <Footer slot="footer" />
</BaseLayout>
