---
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Página no encontrada">
  <Navbar slot="navbar" />
  <div class="flex flex-col items-center justify-center min-h-[60vh] text-center px-4">
    <h1 class="text-6xl font-bold text-gray-300 mb-4">404</h1>
    <p class="text-xl text-gray-500 mb-8">La página que buscas no existe.</p>
    <a
      href="/"
      class="bg-orange-500 text-white px-6 py-3 rounded-lg hover:bg-orange-600 transition-colors font-medium"
    >
      Volver al inicio
    </a>
  </div>
  <Footer slot="footer" />
</BaseLayout>
