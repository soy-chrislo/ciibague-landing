---
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';
import PropertyCard from '../components/PropertyCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { fetchApi } from '../lib/api';
import type { PaginatedPropertiesResponse, Property } from '../types';

let rentProperties: Property[] = [];
let saleProperties: Property[] = [];

try {
  const rentData = await fetchApi<PaginatedPropertiesResponse>('/properties?type=rent&limit=50');
  rentProperties = rentData.items || [];
  const saleData = await fetchApi<PaginatedPropertiesResponse>('/properties?type=sale&limit=50');
  saleProperties = saleData.items || [];
} catch (e) {
  console.error('Error fetching properties:', e);
}
---

<BaseLayout
  title="Inicio"
  description="Encuentra casas, apartamentos, lotes y más para arriendo o venta en Ibagué."
>
  <Navbar slot="navbar" />

  <section class="bg-gray-900 text-white py-16 px-6 text-center">
    <h1 class="text-4xl font-bold mb-4">Contacto Inmobiliario Ibagué</h1>
    <p class="text-lg text-gray-300 max-w-2xl mx-auto">
      Tu agencia inmobiliaria de confianza en Ibagué. Más de 10 años ayudándote a encontrar el
      hogar ideal.
    </p>
  </section>

  {
    rentProperties.length > 0 && (
      <section class="max-w-7xl mx-auto px-4 py-8">
        <div class="flex justify-between items-center mb-4">
          <h2 class="text-2xl font-bold">Inmuebles en Arriendo</h2>
          <a href="/mapa/rent" class="text-orange-500 hover:text-orange-600 font-medium text-sm">
            Ver todos →
          </a>
        </div>
        <div class="flex gap-4 overflow-x-auto pb-4 snap-x">
          {rentProperties.slice(0, 10).map((p) => (
            <PropertyCard
              propertyId={p.id}
              imageSrc={p.photos?.[0]}
              price={String(p.price)}
              address={p.address}
              rooms={p.bedrooms}
              bathrooms={p.bathrooms}
              parkingLots={p.parkingSpots}
              availability={p.available}
              propertyType={p.propertyType}
            />
          ))}
        </div>
      </section>
    )
  }

  {
    saleProperties.length > 0 && (
      <section class="max-w-7xl mx-auto px-4 py-8">
        <div class="flex justify-between items-center mb-4">
          <h2 class="text-2xl font-bold">Inmuebles en Venta</h2>
          <a href="/mapa/sale" class="text-orange-500 hover:text-orange-600 font-medium text-sm">
            Ver todos →
          </a>
        </div>
        <div class="flex gap-4 overflow-x-auto pb-4 snap-x">
          {saleProperties.slice(0, 10).map((p) => (
            <PropertyCard
              propertyId={p.id}
              imageSrc={p.photos?.[0]}
              price={String(p.price)}
              address={p.address}
              rooms={p.bedrooms}
              bathrooms={p.bathrooms}
              parkingLots={p.parkingSpots}
              availability={p.available}
              propertyType={p.propertyType}
            />
          ))}
        </div>
      </section>
    )
  }

  <Footer slot="footer" />
</BaseLayout>
